classDiagram
    class Owner {
        +str name
        +dict~date, int~ available_time
        +dict preferences
        +set_available_time(date, minutes)
        +get_available_time(date) int
        +add_pet(pet)
        +remove_pet(pet_id)
    }

    class Pet {
        +str pet_id
        +str name
        +str species
        +int age
        +str size
        +str owner_id
        +get_info() dict
    }

    class Task {
        +str task_id
        +str name
        +str pet_id
        +int duration_minutes
        +Priority priority
        +TaskStatus status
        +str recurrence
        +start()
        +complete()
        +is_done() bool
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class TaskStatus {
        <<enumeration>>
        NOT_STARTED
        IN_PROGRESS
        DONE
    }

    class Plan {
        +date date
        +int available_time
        +list~Task~ tasks
        +list~Task~ scheduled_tasks
        +list~Task~ unscheduled_tasks
        +generate_plan(owner, pet, tasks)
        +display_plan()
        +explain_plan() str
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Task --> Priority : rated by
    Task --> TaskStatus : tracked by
    Plan --> Owner : uses
    Plan --> Pet : uses
    Plan "1" --> "many" Task : schedules
